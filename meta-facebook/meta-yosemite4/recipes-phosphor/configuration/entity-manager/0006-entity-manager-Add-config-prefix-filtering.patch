From ad1e110794dc9143a25e537f5f0c246bb041c614 Mon Sep 17 00:00:00 2001
From: Eric Yang <eric.yang.wiwynn@gmail.com>
Date: Tue, 11 Mar 2025 13:47:42 +0800
Subject: [PATCH 6/6] entity-manager: Add config-prefix filtering

This change introduces a new option "config-prefix" that enables
filtering of JSON configuration files by their filename prefix.
This feature reduces unnecessary D-Bus overhead and enhances
performance.

Change-Id: I94a1030edfd78b966aba44d5818b1da82f107c86
Signed-off-by: Eric Yang <eric.yang.wiwynn@gmail.com>
---
 meson.build                          |  5 ++
 meson.options                        |  6 +++
 src/entity_manager/configuration.cpp | 17 ++++---
 src/utils.cpp                        | 73 +++++++++++++++++-----------
 src/utils.hpp                        | 12 +++--
 5 files changed, 76 insertions(+), 37 deletions(-)

diff --git a/meson.build b/meson.build
index c8703c1..916fb68 100644
--- a/meson.build
+++ b/meson.build
@@ -7,6 +7,11 @@ project(
     meson_version: '>=1.1.1',
 )
 add_project_arguments('-Wno-psabi', language: 'cpp')
+config_prefix_val = get_option('config-prefix')
+add_project_arguments(
+    '-DCONFIG_PREFIX="@0@"'.format(config_prefix_val),
+    language: 'cpp',
+)
 
 boost_args = [
     '-DBOOST_ASIO_NO_DEPRECATED',
diff --git a/meson.options b/meson.options
index 65c1f97..11fe79d 100644
--- a/meson.options
+++ b/meson.options
@@ -28,3 +28,9 @@ option(
     value: true,
     description: 'Run JSON schema validation during the build.',
 )
+option(
+    'config-prefix',
+    type: 'string',
+    value: 'all',
+    description: 'Comma-separated list of JSON filename prefixes to filter. Default loads all JSON files.',
+)
diff --git a/src/entity_manager/configuration.cpp b/src/entity_manager/configuration.cpp
index 8646f57..a519c1d 100644
--- a/src/entity_manager/configuration.cpp
+++ b/src/entity_manager/configuration.cpp
@@ -35,12 +35,17 @@ bool writeJsonFiles(const nlohmann::json& systemConfiguration)
 // reads json files out of the filesystem
 bool loadConfigurations(std::list<nlohmann::json>& configurations)
 {
+    const std::string configPrefixesEnv = CONFIG_PREFIX;
+    std::vector<std::string> configPrefixes =
+        (configPrefixesEnv != "all" && !configPrefixesEnv.empty())
+            ? splitConfigString(configPrefixesEnv, ',', true)
+            : std::vector<std::string>{};
+
     // find configuration files
     std::vector<std::filesystem::path> jsonPaths;
-    if (!findFiles(
-            std::vector<std::filesystem::path>{configurationDirectory,
-                                               hostConfigurationDirectory},
-            R"(.*\.json)", jsonPaths))
+    if (!findFiles({std::filesystem::path(configurationDirectory),
+                    std::filesystem::path(hostConfigurationDirectory)},
+                   R"(.*\.json)", jsonPaths, configPrefixes))
     {
         std::cerr << "Unable to find any configuration files in "
                   << configurationDirectory << "\n";
@@ -81,8 +86,8 @@ bool loadConfigurations(std::list<nlohmann::json>& configurations)
             continue;
         }
         /*
-        * todo(james): reenable this once less things are in flight
-        *
+         * todo(james): reenable this once less things are in flight
+         *
         if (!validateJson(schema, data))
         {
             std::cerr << "Error validating " << jsonPath.string() << "\n";
