From ee75aceac14e34a15b9703749562058bba6bc72d Mon Sep 17 00:00:00 2001
From: RickyWu-wiwynn <ricky_cx_wu@wiwynn.com>
Date: Wed, 17 Jul 2024 11:33:26 +0800
Subject: [PATCH 5/7] configurations: Revise the Terminus NIC sensor name

1. Revise the Terminus NIC temperature sensor name to NICX_TEMP_C.
2. Revise the temperature threshold.
---
 configurations/meta/terminus_2x100g_nic_tsff.json | 6 +++---
 1 file changed, 3 insertions(+), 3 deletions(-)

diff --git a/configurations/meta/terminus_2x100g_nic_tsff.json b/configurations/meta/terminus_2x100g_nic_tsff.json
index 0d19e6b..c40e222 100644
--- a/configurations/meta/terminus_2x100g_nic_tsff.json
+++ b/configurations/meta/terminus_2x100g_nic_tsff.json
@@ -3,7 +3,7 @@
         {
             "Address": "$address",
             "Bus": "$bus",
-            "Name": "Terminus NIC FRU $bus",
+            "Name": "Terminus NIC FRU $bus % 24",
             "Type": "EEPROM"
         },
         {
@@ -12,7 +12,7 @@
             "Labels": [
                 "temp1"
             ],
-            "Name": "NIC TEMP $bus",
+            "Name": "NIC$bus % 24 TEMP_C",
             "Thresholds": [
                 {
                     "Direction": "greater than",
@@ -32,7 +32,7 @@
             "Type": "EMC1403"
         }
     ],
-    "Name": "Terminus NIC FRU $bus",
+    "Name": "Terminus NIC FRU $bus % 24",
     "Probe": "xyz.openbmc_project.FruDevice({'BOARD_PRODUCT_NAME': 'Terminus 2x100G NIC TSFF'})",
     "Type": "Board",
     "xyz.openbmc_project.Inventory.Decorator.Asset": {
