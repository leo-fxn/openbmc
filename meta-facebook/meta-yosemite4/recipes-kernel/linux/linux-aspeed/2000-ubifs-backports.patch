 	dir->i_mtime = inode_set_ctime_to_ts(dir, inode_get_ctime(inode));
-	err = ubifs_jnl_update(c, dir, &nm, inode, 0, 0);
+	err = ubifs_jnl_update(c, dir, &nm, inode, 0, 0, 0);
