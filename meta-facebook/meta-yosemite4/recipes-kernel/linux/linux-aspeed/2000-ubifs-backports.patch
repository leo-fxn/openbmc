 	if (err)
 		goto out_inode;
 
+	set_nlink(inode, 1);
 	mutex_lock(&dir_ui->ui_mutex);
 	dir->i_size += sz_change;
 	dir_ui->ui_size = dir->i_size;
 	dir->i_mtime = inode_set_ctime_to_ts(dir, inode_get_ctime(inode));
-	err = ubifs_jnl_update(c, dir, &nm, inode, 0, 0, 0);
