From 30f9cd1e9273bfecb84dfc62b81082f514803316 Mon Sep 17 00:00:00 2001
From: Potin Lai <potin.lai@quantatw.com>
Date: Thu, 6 Feb 2025 13:38:04 +0800
Subject: [PATCH 103/105] dbus-sensors: Fix SatelliteSensor build errors

Fix the build errors to work with latest openbmc/dbus-sensor repo

Change-Id: If832a46f3e012bef6c293a6051a67b48b8ae7cee
---
 src/satellite/SatelliteSensor.cpp | 12 ++++--------
 1 file changed, 4 insertions(+), 8 deletions(-)

diff --git a/src/satellite/SatelliteSensor.cpp b/src/satellite/SatelliteSensor.cpp
index 2e318e7..28be465 100644
--- a/src/satellite/SatelliteSensor.cpp
+++ b/src/satellite/SatelliteSensor.cpp
@@ -303,7 +303,7 @@ void SatelliteSensor::read()
     if (!readingStateGood())
     {
         markAvailable(false);
-        updateValueOnly(std::numeric_limits<double>::quiet_NaN());
+        updateValue(std::numeric_limits<double>::quiet_NaN());
         restartRead();
         return;
     }
@@ -339,7 +339,7 @@ void SatelliteSensor::read()
         {
             lg2::error("Value update to {TEMP}", "TEMP", temp);
         }
-        updateValueOnly(temp);
+        updateValue(temp);
     }
     else
     {
@@ -403,11 +403,7 @@ void createSensors(
 
                 size_t rate = loadVariant<uint8_t>(entry.second, "PollRate");
 
-                std::string powerSate = loadVariant<std::string>(entry.second,
-                                                                 "PowerState");
-
-                PowerState pwrState;
-                setReadState(powerSate, pwrState);
+                PowerState pwrState = getPowerState(entry.second);
 
                 double minVal = loadVariant<double>(entry.second, "MinValue");
 
@@ -427,7 +423,7 @@ void createSensors(
                               "\tMaxValue: {MAX}\n",
                               "CONF", entry.first, "NAME", name, "BUS",
                               static_cast<int>(busId), "ADDR",
-                              static_cast<int>(addr), "PWRSTATE", powerSate,
+                              static_cast<int>(addr), "PWRSTATE", static_cast<int>(pwrState),
                               "OFF", static_cast<int>(off), "TYPE", sensorType,
                               "VALUETYPE", valueType, "RATE", rate, "MIN",
                               static_cast<double>(minVal), "MAX",
-- 
2.47.1

