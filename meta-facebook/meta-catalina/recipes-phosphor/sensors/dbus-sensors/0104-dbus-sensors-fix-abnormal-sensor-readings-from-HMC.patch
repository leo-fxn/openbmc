From 1f52570a2adaa7b73d0a7d92fa1e72aefaf291f5 Mon Sep 17 00:00:00 2001
From: Potin Lai <potin.lai@quantatw.com>
Date: Thu, 6 Feb 2025 13:40:38 +0800
Subject: [PATCH 104/105] dbus-sensors: fix abnormal sensor readings from HMC

There is a known issue that HMC reports abnormal temperature reading sometimes.
Add upper & lower filter to discard the abnormal values.

NVBug: 5030119
Change-Id: I223871cc4c2ec5b80e299ace57dde122877c4e44
---
 src/satellite/SatelliteSensor.cpp | 12 +++++++++++-
 1 file changed, 11 insertions(+), 1 deletion(-)

diff --git a/src/satellite/SatelliteSensor.cpp b/src/satellite/SatelliteSensor.cpp
index 28be465..45388b4 100644
--- a/src/satellite/SatelliteSensor.cpp
+++ b/src/satellite/SatelliteSensor.cpp
@@ -43,6 +43,8 @@ extern "C"
 #include <linux/i2c-dev.h>
 }
 
+constexpr const double upperTemperatureReadingFilter = 255;
+constexpr const double lowerTemperatureReadingFilter = -255;
 constexpr const bool debug = false;
 
 constexpr const char* configInterface =
@@ -339,7 +341,15 @@ void SatelliteSensor::read()
         {
             lg2::error("Value update to {TEMP}", "TEMP", temp);
         }
-        updateValue(temp);
+
+        if ((sensorType == "Temperature") && ((temp < lowerTemperatureReadingFilter) || (temp > upperTemperatureReadingFilter)))
+        {
+            lg2::error("Abnormal sensor reading from HMC, sensor: {NAME}, value: {VALUE}", "NAME", name, "VALUE", temp);
+        }
+        else
+        {
+            updateValue(temp);
+        }
     }
     else
     {
-- 
