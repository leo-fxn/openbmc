From 465cb9c884ab3ac1b3e4f852384cdc0343835c36 Mon Sep 17 00:00:00 2001
From: Chester Lin <chesterl@nvidia.com>
Date: Tue, 4 Feb 2025 12:15:38 +0800
Subject: [PATCH 1/1] SatelliteSensor: improve I2C transactions by repeat START

Improve I2C direct sensor polling by combining w/r transactions with
a repeated START since ast2600's i2c new-driver mode can't handle
separated write & read transactions on the i2c-slave-eeprom properly.

Meanwhile, combining with a repeated START can improve performance
and ensure an atomic access (e.g. move offset & read) to the virtual
eeprom.

* Old approach:
  START -> write trans -> STOP -> START -> read trans -> STOP
* New approach:
  START -> write trans -> Repeated START -> read trans -> STOP

Fixes nvbug https://nvbugspro.nvidia.com/bug/5030119
Signed-off-by: Chester Lin <chesterl@nvidia.com>
---
Reference from NVIDIA Github
[1] https://github.com/NVIDIA/dbus-sensors/commit/ffc1b6e42c48f4fbb4ef6ea19b1d04bc0a40cee9
---
 src/satellite/SatelliteSensor.cpp | 55 ++++++++++++++++---------------
 src/satellite/SatelliteSensor.hpp |  3 +-
 2 files changed, 30 insertions(+), 28 deletions(-)

diff --git a/src/satellite/SatelliteSensor.cpp b/src/satellite/SatelliteSensor.cpp
index 45388b4..343e1fc 100644
--- a/src/satellite/SatelliteSensor.cpp
+++ b/src/satellite/SatelliteSensor.cpp
@@ -141,7 +141,7 @@ void SatelliteSensor::checkThresholds()
 }
 
 template <typename T>
-int i2cCmd(uint8_t bus, uint8_t addr, size_t offset, T* reading, int length)
+int i2cCmd(uint8_t bus, uint8_t addr, size_t offset, T* reading, uint8_t length)
 {
     std::string i2cBus = "/dev/i2c-" + std::to_string(bus);
 
@@ -164,43 +164,44 @@ int i2cCmd(uint8_t bus, uint8_t addr, size_t offset, T* reading, int length)
     }
 
     int ret = 0;
-    struct i2c_rdwr_ioctl_data args = {nullptr, 0};
-    struct i2c_msg msg = {0, 0, 0, nullptr};
     std::array<uint8_t, 8> cmd{};
+    T data = 0;
+
+    if (length > sizeof(data))
+    {
+        lg2::error("wrong i2c data length");
+        close(fd);
+        return -1;
+    }
 
-    msg.addr = addr;
-    args.msgs = &msg;
-    args.nmsgs = 1;
+    struct i2c_msg msgs[2] = {{
+                                  // write offset
+                                  .addr = addr,
+                                  .flags = 0,
+                                  .len = 2,
+                                  .buf = cmd.data(),
+                              },
+                              {// read data from the offset
+                               .addr = addr,
+                               .flags = I2C_M_RD,
+                               .len = length,
+                               .buf = (uint8_t*)&data}};
+
+    struct i2c_rdwr_ioctl_data args = {msgs, 2};
 
-    msg.flags = 0;
-    msg.buf = cmd.data();
     // handle two bytes offset
     if (offset > 255)
     {
-        msg.len = 2;
-        msg.buf[0] = offset >> 8;
-        msg.buf[1] = offset & 0xFF;
+        msgs[0].len = 2;
+        msgs[0].buf[0] = offset >> 8;
+        msgs[0].buf[1] = offset & 0xFF;
     }
     else
     {
-        msg.len = 1;
-        msg.buf[0] = offset & 0xFF;
-    }
-
-    // write offset
-    // NOLINTNEXTLINE(cppcoreguidelines-pro-type-vararg)
-    ret = ioctl(fd, I2C_RDWR, &args);
-    if (ret < 0)
-    {
-        close(fd);
-        return ret;
+        msgs[0].len = 1;
+        msgs[0].buf[0] = offset & 0xFF;
     }
 
-    T data = 0;
-    msg.flags = I2C_M_RD;
-    msg.len = length;
-    msg.buf = (uint8_t*)&data;
-
     // NOLINTNEXTLINE(cppcoreguidelines-pro-type-vararg)
     ret = ioctl(fd, I2C_RDWR, &args);
     if (ret < 0)
diff --git a/src/satellite/SatelliteSensor.hpp b/src/satellite/SatelliteSensor.hpp
index a3b4888..4df145a 100644
--- a/src/satellite/SatelliteSensor.hpp
+++ b/src/satellite/SatelliteSensor.hpp
@@ -34,7 +34,8 @@
 #endif
 
 template <typename T>
-int i2cCmd(uint8_t bus, uint8_t addr, size_t offset, T* reading, int length);
+int i2cCmd(uint8_t bus, uint8_t addr, size_t offset, T* reading,
+           uint8_t length);
 
 struct SatelliteSensor : public Sensor
 {
