From 000bdb93dce2290e6f898681b9ee820d75664dde Mon Sep 17 00:00:00 2001
From: Potin Lai <potin.lai@quantatw.com>
Date: Tue, 18 Jun 2024 23:44:55 +0800
Subject: [PATCH 101/105] dbus-sensors: setup SatelliteSensor meson build

Setup SatelliteSensor meson build for adding ability to extent source code in meta-openbmc repo.

Change-Id: I3b20e8538743d9a17602c0aa55ff862df30fcd70
---
 meson.build               | 4 ++++
 meson.options             | 6 ++++++
 service_files/meson.build | 1 +
 src/meson.build           | 4 ++++
 4 files changed, 15 insertions(+)

diff --git a/meson.build b/meson.build
index d1f1207..8e49f6d 100644
--- a/meson.build
+++ b/meson.build
@@ -49,5 +49,9 @@ default_deps = [
     uring,
 ]
 
+if get_option('satellite').enabled()
+    add_project_arguments('-DAUTO_GEN_SENSOR_HEADER', language : 'cpp')
+endif
+
 subdir('service_files')
 subdir('src')
diff --git a/meson.options b/meson.options
index de733c9..cf69fe5 100644
--- a/meson.options
+++ b/meson.options
@@ -83,3 +83,9 @@ option(
     value: 'disabled',
     description: 'Enables Sensor override feature without any check.',
 )
+option(
+    'satellite',
+    type: 'feature',
+    value: 'disabled',
+    description: 'Enable Satellite sensor.',
+)
\ No newline at end of file
diff --git a/service_files/meson.build b/service_files/meson.build
index c3b23e0..a1e475d 100644
--- a/service_files/meson.build
+++ b/service_files/meson.build
@@ -17,6 +17,7 @@ unit_files = [
     ['nvme', 'xyz.openbmc_project.nvmesensor.service'],
     ['psu', 'xyz.openbmc_project.psusensor.service'],
     ['external', 'xyz.openbmc_project.externalsensor.service'],
+    ['satellite', 'xyz.openbmc_project.satellitesensor.service'],
 ]
 
 fs = import('fs')
diff --git a/src/meson.build b/src/meson.build
index ca995e5..034826d 100644
--- a/src/meson.build
+++ b/src/meson.build
@@ -118,3 +118,7 @@ endif
 if get_option('tests').allowed()
     subdir('tests')
 endif
+
+if get_option('satellite').enabled()
+    subdir('satellite')
+endif
\ No newline at end of file
-- 
2.47.1

