#!/bin/bash

eid=10
max_retry_count=3
retry_delay_sec=1

pwr_asci_good_gpio_chip="gpiochip2"
pwr_asci_good_line=92

component_names=(
    ["1"]="Minerva_Aegis_vr_osfp_p3v3"
    ["2"]="Minerva_Aegis_vr_cpu_p0v85_pvdd"
    ["3"]="Minerva_Aegis_vr_cpu_p0v75_pvdd_ch_n"
    ["4"]="Minerva_Aegis_vr_cpu_p0v75_pvdd_ch_s"
    ["5"]="Minerva_Aegis_vr_cpu_p0v75_trvdd_zonea"
    ["6"]="Minerva_Aegis_vr_cpu_p0v75_trvdd_zoneb"
    ["7"]="Minerva_Aegis_vr_cpu_p1v1_vddc_hbm0_2_4"
    ["8"]="Minerva_Aegis_vr_cpu_p0v9_trvdd_zonea"
    ["9"]="Minerva_Aegis_vr_cpu_p0v9_trvdd_zoneb"
    ["10"]="Minerva_Aegis_vr_cpu_p1v1_vddc_hbm1_3_5"
    ["11"]="Minerva_Aegis_vr_cpu_p0v8_vdda_pcie"
)


gpio_value=$(gpioget "$pwr_asci_good_gpio_chip" "$pwr_asci_good_line" 2>/dev/null)
gpioget_status=$?

if [ $gpioget_status -eq 0 ]; then
    echo "power-asci-good value: $gpio_value"
    
    if [ -n "$gpio_value" ] && [ "$gpio_value" -eq 0 ] 2>/dev/null; then
        echo "Failed to set version: the power-asci-good is not high"
        exit 1
    fi
else
    echo "gpioget failed, skipping check"
fi

version=""
for ((i=1; i<=max_retry_count; i++)); do
    output=$(pldmtool fw_update GetFwParams -m "$eid" | 
                jq --raw-output '.ComponentParameterEntries[] | 
                (.ComponentIdentifier | tostring) + "#" + 
                .ActiveComponentVersionString')

    if [ -z "$output" ]; then
        echo "pldmtool returned empty output, retry after ${retry_delay_sec} seconds (count: ${i})"
        sleep "$retry_delay_sec"
    else
        while IFS="#" read -r compId version; do
            component_name=${component_names[$compId]:-"Unknown"}
            if [ "$component_name" == "Unknown" ]; then
                continue
            fi

            echo "$component_name version: $version"

            busctl set-property \
                xyz.openbmc_project.Settings \
                "/xyz/openbmc_project/software/chassis/$component_name" \
                xyz.openbmc_project.Software.Version \
                Version "s" "$version"
        done <<< "$output"
        
        break
    fi
done
