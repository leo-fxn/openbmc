From f35d8cdf7ce9155b93c34b2cd2abe63551e65b2a Mon Sep 17 00:00:00 2001
From: EricYang-wiwynn <Eric_Yang@wiwynn.com>
Date: Mon, 17 Mar 2025 18:54:44 +0800
Subject: [PATCH] mctpd: Implement retry mechanism for static EID setup

Added a retry logic to the setup_static_eid function to enhance
robustness when calling the GetSubTreePaths method.
---
 src/mctpd.c | 47 +++++++++++++++++++++++++++++++++++++----------
 1 file changed, 37 insertions(+), 10 deletions(-)

diff --git a/src/mctpd.c b/src/mctpd.c
index 9ffae05..4b59e53 100644
--- a/src/mctpd.c
+++ b/src/mctpd.c
@@ -2024,16 +2024,43 @@ static int setup_static_eid(ctx *ctx)
 	req.ctrl_hdr.command_code = MCTP_CTRL_CMD_GET_ENDPOINT_ID;
 	sd_bus_error error = SD_BUS_ERROR_NULL;
 	sd_bus_message *message = NULL;
-
-	int rc = sd_bus_call_method(ctx->bus,
-		OPENBMC_OBJECT_MAPPER, OPENBMC_OBJECT_MAPPER_OBJECT_PATH,
-		OPENBMC_OBJECT_MAPPER_IFACE, "GetSubTreePaths",
-		&error, &message, "sias", "/xyz/openbmc_project/", 0, 1,
-		OPENBMC_MCTP_CONFIG_IFACE);
-	if (rc < 0) {
-		warnx("Failed to issue method call: %s", error.message);
-		goto out;
-	}
+	int rc;
+	int retry_count = 0;
+	const int max_retries = 4;
+
+	do {
+			rc = sd_bus_call_method(
+				ctx->bus,
+				OPENBMC_OBJECT_MAPPER,
+				OPENBMC_OBJECT_MAPPER_OBJECT_PATH,
+				OPENBMC_OBJECT_MAPPER_IFACE,
+				"GetSubTreePaths",
+				&error,
+				&message,
+				"sias",
+				"/xyz/openbmc_project/",
+				0,
+				1,
+				OPENBMC_MCTP_CONFIG_IFACE);
+			if (rc < 0) {
+					warnx(
+						"Attempt %d: Failed to issue method call: %s, rc = %d",
+						retry_count + 1,
+						error.message,
+						rc);
+					if (retry_count < max_retries) {
+							retry_count++;
+							warnx(
+								"Retrying... (%d/%d)",
+								retry_count,
+								max_retries);
+							sd_bus_error_free(&error);
+					} else {
+							warnx("Max retries reached. Aborting.");
+							goto out;
+					}
+			}
+	} while (rc < 0 && retry_count <= max_retries);
 
 	sd_bus_message_read_strv(message, &object_paths);
 	message = sd_bus_message_unref(message);
-- 
2.25.1

