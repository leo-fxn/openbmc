Subject: [PATCH 1/2] Also allow power policy when watchdog flag is raised

Change-Id: I333abc0313a6560ce509c9481e9b92e592f5ad80
---
 discover_system_state.cpp | 3 +--
 1 file changed, 1 insertion(+), 2 deletions(-)

diff --git a/discover_system_state.cpp b/discover_system_state.cpp
index 2153e7c..b837088 100644
--- a/discover_system_state.cpp
+++ b/discover_system_state.cpp
@@ -114,8 +114,7 @@ int main(int argc, char** argv)
     if (bmcRebootCause == BMC::RebootCause::Software)
     {
         info(
-            "BMC was reset due to cold reset, no power restore policy will be run");
-        return 0;
+            "The LastbootCause is a watchdog. Power policy execution is currently allowed");
     }
 #endif // RUN_APR_ON_SOFTWARE_RESET
 #endif
