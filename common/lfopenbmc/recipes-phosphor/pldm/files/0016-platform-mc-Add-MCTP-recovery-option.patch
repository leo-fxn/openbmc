From a5579dbaf5c2b92e9c29dc89dca4731777f59f53 Mon Sep 17 00:00:00 2001
From: Eric Yang <eric.yang.wiwynn@gmail.com>
Date: Thu, 6 Mar 2025 16:48:20 +0800
Subject: [PATCH 16/18] platform-mc: Add MCTP recovery option

Allow enabling or disabling MCTP 2.0 recovery feature.
Calls `.Recover` method on timeout to handle communication recovery.

Change-Id: I298a1b397495496622254de80c67e081ec104945
Signed-off-by: Eric Yang <eric.yang.wiwynn@gmail.com>
Upstream-Status: Pending
---
 common/utils.cpp                 | 4 ++++
 meson.build                      | 1 +
 meson.options                    | 8 ++++++++
 platform-mc/terminus_manager.cpp | 2 ++
 4 files changed, 15 insertions(+)

diff --git a/common/utils.cpp b/common/utils.cpp
index 88f887e..5b1aaaa 100644
--- a/common/utils.cpp
+++ b/common/utils.cpp
@@ -563,6 +563,7 @@ int emitStateSensorEventSignal(uint8_t tid, uint16_t sensorId,
 
 void recoverMctpEndpoint(const std::string& endpointObjPath)
 {
+#ifdef MCTP_RECOVERY
     auto& bus = DBusHandler::getBus();
     try
     {
@@ -580,6 +581,9 @@ void recoverMctpEndpoint(const std::string& endpointObjPath)
             "failed to make a D-Bus call to recover MCTP Endpoint, ERROR {ERR_EXCEP}",
             "ERR_EXCEP", e);
     }
+#else
+    [[maybe_unused]] auto& _endpointObjPath = endpointObjPath;
+#endif
 }
 
 uint16_t findStateSensorId(const pldm_pdr* pdrRepo, uint8_t tid,
diff --git a/meson.build b/meson.build
index f616f69..a183b28 100644
--- a/meson.build
+++ b/meson.build
@@ -137,6 +137,7 @@ conf_data.set(
     get_option('default-sensor-update-interval'),
 )
 conf_data.set('SENSOR_POLLING_TIME', get_option('sensor-polling-time'))
+conf_data.set('MCTP_RECOVERY', get_option('mctp-recovery').allowed())
 
 configure_file(output: 'config.h', configuration: conf_data)
 
diff --git a/meson.options b/meson.options
index 1ebeff3..b4c9c3d 100644
--- a/meson.options
+++ b/meson.options
@@ -220,3 +220,11 @@ option(
                     `GetSensorReading` if the sensor need to be updated.''',
     value: 249,
 )
+
+## MCTP Recovery Option
+option(
+    'mctp-recovery',
+    type: 'feature',
+    description: 'Recovery in request timeout. Calls `.Recover` method on timeout to handle communication recovery',
+    value: 'enabled',
+)
diff --git a/platform-mc/terminus_manager.cpp b/platform-mc/terminus_manager.cpp
index 85b2f53..767b9e8 100644
--- a/platform-mc/terminus_manager.cpp
+++ b/platform-mc/terminus_manager.cpp
@@ -673,6 +673,7 @@ exec::task<int> TerminusManager::sendRecvPldmMsg(
     auto rc = co_await sendRecvPldmMsgOverMctp(eid, request, responseMsg,
                                                responseLen);
 
+#ifdef MCTP_RECOVERY
     if (rc == PLDM_ERROR_NOT_READY)
     {
         // Call Recover() to check enpoint's availability
@@ -684,6 +685,7 @@ exec::task<int> TerminusManager::sendRecvPldmMsg(
         pldm::utils::recoverMctpEndpoint(endpointObjPath);
         updateMctpEndpointAvailability(mctpInfo.value(), false);
     }
+#endif
 
     co_return rc;
 }
-- 
