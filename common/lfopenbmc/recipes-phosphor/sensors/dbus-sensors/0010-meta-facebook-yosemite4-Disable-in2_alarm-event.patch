From b715300787ca35e529354f17b765575d3f30c679 Mon Sep 17 00:00:00 2001
From: KayYCHuang-wiwynn <kay.yc.huang.wiwynn@gmail.com>
Date: Mon, 17 Mar 2025 02:25:46 +0000
Subject: [PATCH 10/11] meta-facebook: yosemite4: Disable in2_alarm event

---
 meson.build               | 4 ++++
 meson.options             | 6 ++++++
 src/psu/PSUSensorMain.cpp | 2 ++
 3 files changed, 12 insertions(+)

diff --git a/meson.build b/meson.build
index 3aeff4c..ab277c7 100644
--- a/meson.build
+++ b/meson.build
@@ -31,6 +31,10 @@ add_project_arguments(
     language: 'cpp',
 )
 
+if get_option('disable-in2-alarm-event')
+    add_project_arguments('-DDISABLE_IN2_ALARM_EVENT', language : 'cpp')
+endif
+
 threads = dependency('threads')
 # i2c-tools doesn't ship a pkg-config file for libi2c
 i2c = meson.get_compiler('cpp').find_library('i2c')
diff --git a/meson.options b/meson.options
index c9405ce..c4c21a7 100644
--- a/meson.options
+++ b/meson.options
@@ -89,3 +89,9 @@ option(
     value: false,
     description: 'Disable host power monitoring for hwmon-temp.',
 )
+option(
+    'disable-in2-alarm-event',
+    type: 'boolean',
+    value: 'false',
+    description: 'Disable in2_alarm event.',
+)
diff --git a/src/psu/PSUSensorMain.cpp b/src/psu/PSUSensorMain.cpp
index b1286df..5cf8bc7 100644
--- a/src/psu/PSUSensorMain.cpp
+++ b/src/psu/PSUSensorMain.cpp
@@ -1170,7 +1170,9 @@ void propertyInitialize()
                        {"Failure", {"crit_alarm", "lcrit_alarm"}}};
 
     eventMatch = {{"PredictiveFailure", {"power1_alarm"}},
+#ifndef DISABLE_IN2_ALARM_EVENT
                   {"Failure", {"in2_alarm"}},
+#endif
                   {"ACLost", {"in1_beep"}},
                   {"ConfigureError", {"in1_fault"}}};
 
