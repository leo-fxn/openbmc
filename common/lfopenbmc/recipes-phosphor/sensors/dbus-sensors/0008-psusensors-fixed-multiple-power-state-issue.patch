From 3f89f0147eb9bbadc96fb751b280b826d01a9559 Mon Sep 17 00:00:00 2001
From: Peter Yin <peter.yin@quantatw.com>
Date: Thu, 23 Jan 2025 14:27:45 +0800
Subject: [PATCH 8/8] psusensors: fixed multiple power state issue

Link:https://gerrit.openbmc.org/c/openbmc/dbus-sensors/+/77391

If the entity does not set powerState for each channel,
label_powerState will be contaminated by the state of the previous
channel. Therefore, if label_powerState is not found,the powerState
should be updated.

Change-Id: I61d68834a006dec9f355d1b3f2a339ee30ada89d
Signed-off-by: Peter Yin <peter.yin@quantatw.com>
---
 src/psu/PSUSensorMain.cpp | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/src/psu/PSUSensorMain.cpp b/src/psu/PSUSensorMain.cpp
index bcb7894..e12519e 100644
--- a/src/psu/PSUSensorMain.cpp
+++ b/src/psu/PSUSensorMain.cpp
@@ -832,6 +832,10 @@ static void createSensorsCallback(
                                                     findPowerState->second);
                 setReadState(powerState, readState);
             }
+            else
+            {
+                readState = getPowerState(*baseConfig);
+            }
             if (!(psuProperty.minReading < psuProperty.maxReading))
             {
                 std::cerr << "Min must be less than Max\n";
-- 
2.25.1

