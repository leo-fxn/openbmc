From c4a633a5e540f971965994970093c5e147b34b05 Mon Sep 17 00:00:00 2001
From: Amithash Prasasd <amithash@meta.com>
Date: Thu, 21 Nov 2024 21:00:02 -0800
Subject: [PATCH 06/11] Add structured logging for Threshold events

Add capability to create structured logs for threshold crossing
(compatible with Redfish Sensor Events) along with ability to
resolve the logs when the threshold event recovers.

Tested:
Create a fake external sensor named HostDevTemp with Lower Critical
Threshold as 10 and Upper Critical Threshold as 20.
Note: busctl output was modified to ease readability -- Removed
emits-change and writable

Move sensors below lower threshold and get log. We expect a new log
entry with message ReadingBelowLowerCriticalThreshold and Resolved
as false.
```
root@bmc:~# busctl introspect -l xyz.openbmc_project.Logging /xyz/openbmc_project/logging/entry/2 xyz.openbmc_project.Logging.Entry | grep "AdditionalData\|Message\|Resolved"
.AdditionalData                   property  as        8 "READING_VALUE=1.0" "SENSOR_NAME=/xyz/openbmc_project/sensors/temperature/HostDevTemp" "THRESHOLD_VALUE=10.0" "UNITS=xyz.openbmc_project.Sensor.Value.Unit.DegreesC" "_CODE_FILE=<snip>" "_CODE_FUNC=<snip>" "_CODE_LINE=588" "_PID=687"
.Message                          property  s         "xyz.openbmc_project.Sensor.Threshold.ReadingBelowLowerCriticalThreshold"
.Resolved                         property  b         false
```
Move sensor back to normal reading. Expected, first log Resolved set
to true and there is a new event log for SensorReadingNormalRange
```
root@bmc:~# busctl introspect -l xyz.openbmc_project.Logging /xyz/openbmc_project/logging/entry/2 xyz.openbmc_project.Logging.Entry | grep "AdditionalData\|Message\|Resolved"
.AdditionalData                   property  as        8 "READING_VALUE=1.0" "SENSOR_NAME=/xyz/openbmc_project/sensors/temperature/HostDevTemp" "THRESHOLD_VALUE=10.0" "UNITS=xyz.openbmc_project.Sensor.Value.Unit.DegreesC" "_CODE_FILE=<snip>" "_CODE_FUNC=<snip>" "_CODE_LINE=588" "_PID=687"
.Message                          property  s         "xyz.openbmc_project.Sensor.Threshold.ReadingBelowLowerCriticalThreshold"
.Resolved                         property  b         true

root@bmc:~# busctl introspect -l xyz.openbmc_project.Logging /xyz/openbmc_project/logging/entry/4 xyz.openbmc_project.Logging.Entry | grep "AdditionalData\|Message\|Resolved"
.AdditionalData                   property  as        7 "READING_VALUE=15.0" "SENSOR_NAME=/xyz/openbmc_project/sensors/temperature/HostDevTemp" "UNITS=xyz.openbmc_project.Sensor.Value.Unit.DegreesC" "_CODE_FILE=<snip>" "_CODE_FUNC=<snip>" "_CODE_LINE=500" "_PID=687"
.Message                          property  s         "xyz.openbmc_project.Sensor.Threshold.SensorReadingNormalRange"
.Resolved                         property  b         false
```
Repeat for Upper Critical Threshold.

