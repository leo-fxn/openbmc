    [bmcweb] Up the max connections from 200 to 1000
    Summary:

    biggerboat

    Test Plan: it builds

    Reviewers:

    Subscribers:

    Tasks: T215749840

    Tags:
---
 http/http_connection.hpp | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/http/http_connection.hpp b/http/http_connection.hpp
index a923f5ec..2d0a03b1 100644
--- a/http/http_connection.hpp
+++ b/http/http_connection.hpp
@@ -205,7 +205,7 @@ class Connection :
     {
         BMCWEB_LOG_DEBUG("{} Connection started, total {}", logPtr(this),
                          connectionCount);
-        if (connectionCount >= 200)
+        if (connectionCount >= 1000)
         {
             BMCWEB_LOG_CRITICAL("{} Max connection count exceeded.",
                                 logPtr(this));
