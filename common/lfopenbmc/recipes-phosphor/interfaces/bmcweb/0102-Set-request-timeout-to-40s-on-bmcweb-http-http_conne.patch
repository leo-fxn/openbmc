From c76051de7323f7429ee678ef3ffc4ac429520c6c Mon Sep 17 00:00:00 2001
From: Marco Kawajiri <kawajiri@meta.com>
Date: Wed, 5 Feb 2025 09:42:22 -0800
Subject: [PATCH] Set request timeout to 40s on bmcweb/http/http_connection.hpp

---
 http/http_connection.hpp | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/http/http_connection.hpp b/http/http_connection.hpp
index 9106764..ed8b204 100644
--- a/http/http_connection.hpp
+++ b/http/http_connection.hpp
@@ -759,7 +759,7 @@ class Connection :
             return;
         }
 
-        std::chrono::seconds timeout(15);
+        std::chrono::seconds timeout(40);
 
         std::weak_ptr<Connection<Adaptor, Handler>> weakSelf = weak_from_this();
         timer.expires_after(timeout);
-- 
