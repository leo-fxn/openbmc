From 6ed48db5254d070adaa15374483a4f4e79e7f63d Mon Sep 17 00:00:00 2001
From: Potin Lai <potin.lai@quantatw.com>
Date: Wed, 2 Apr 2025 09:56:41 +0800
Subject: [PATCH 1/1] log_services: fix event log sorting issue causing crashes

We observed that when the event log contains more than 16 entries,
Redfish fails to fetch the logs, and bmcweb crashes.

The issue arises from using an incorrect comparison function in
`std::ranges::sort()`, which does not return a boolean. This leads to
unstable behavior and potential crashes.

To resolve this, we modify the comparison function to
`return redfish::json_util::objectKeyCmp("Id", left, right) < 0;`

Signed-off-by: Potin Lai <potin.lai@quantatw.com>
Change-Id: If76d478e3fc32b1c39a33247e7a7a39ff9e4f63d
---
 redfish-core/lib/log_services.hpp | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/redfish-core/lib/log_services.hpp b/redfish-core/lib/log_services.hpp
index 87b44529..7cff4d97 100644
--- a/redfish-core/lib/log_services.hpp
+++ b/redfish-core/lib/log_services.hpp
@@ -1550,7 +1550,7 @@ inline void afterLogEntriesGetManagedObjects(
 
     std::ranges::sort(entriesArray, [](const nlohmann::json& left,
                                        const nlohmann::json& right) {
-        return redfish::json_util::objectKeyCmp("Id", left, right);
+        return redfish::json_util::objectKeyCmp("Id", left, right) < 0;
     });
     asyncResp->res.jsonValue["Members@odata.count"] = entriesArray.size();
     asyncResp->res.jsonValue["Members"] = std::move(entriesArray);
